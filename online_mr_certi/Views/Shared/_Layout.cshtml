        <div class="wa-card" id="wa-card">
            <div class="wa-header">
                <div class="wa-header-icon"><i class="fa-brands fa-whatsapp"></i></div>
                <div class="wa-header-text">
                    <strong>Marriage System Support</strong>
                    <span>Typically replies instantly</span>
                </div>
                <button class="wa-header-close" onclick="toggleWA()">&times;</button>
            </div>

            <!-- Qaybta leh Background-ka iyo Qoraalka weyn -->
            <div class="wa-body">
                <p><strong>Assalamu Alaikum! 👋</strong></p>
                <p class="wa-main-text">
                    Welcome to the <strong>Yaqshiid District Court</strong> digital portal.
                    Do you need assistance with your marriage certificate application or tracking your request?
                    Our dedicated support team is online and ready to guide you through every step!
                </p>
            </div>

            <div class="wa-footer">
                <!-- Fariinta diyaar furan (Start Chat) -->
                <a href="https://wa.me/252619979258?text=Assalamu%20Alaikum!%20I%20need%20assistance%20with%20my%20marriage%20certificate%20application%20at%20Yaqshiid%20District%20Court."
                   target="_blank" class="wa-start-btn">
                    <i class="fa-brands fa-whatsapp"></i> Start Chat
                </a>
            </div>
        </div>

        <!-- Badanka Floating Button-ka ah oo leh Pulse -->
        <div class="wa-float-container" onclick="toggleWA()">
            <div class="wa-pulse"></div>
            <div class="wa-pulse delay"></div>
            <button class="wa-float-btn">
                <i class="fa-brands fa-whatsapp"></i>
            </button>
        </div>
    </div>
    <!-- ══════════ SCRIPTS ══════════ -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function toggleWA() {
            var card = document.getElementById('wa-card');
            card.style.display = (card.style.display === 'block') ? 'none' : 'block';
        }
        function toggleMobileNav() {
            var links = document.querySelector('.nav-links');
            links.style.display = (links.style.display === 'flex') ? 'none' : 'flex';
            links.style.flexDirection = 'column';
            links.style.position = 'absolute';
            links.style.top = '64px';
            links.style.left = '0';
            links.style.right = '0';
            links.style.background = 'rgba(10,10,18,0.97)';
            links.style.padding = '20px';
            links.style.gap = '16px';
        }
    </script>
    

    <!-- ══════════ SCRIPTS ══════════ -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        /* ── DARK MODE ── */
                function applyTheme(t) {
            // Labadaba html iyo body si aad u hubiso
            document.documentElement.setAttribute('data-theme', t);
            document.body.setAttribute('data-theme', t);

            document.getElementById('icon-sun').style.display  = t === 'dark' ? 'block' : 'none';
            document.getElementById('icon-moon').style.display = t === 'dark' ? 'none'  : 'block';
            localStorage.setItem('mcTheme', t);
        }

        function toggleTheme() {
            var cur = document.documentElement.getAttribute('data-theme') || 'light';
            applyTheme(cur === 'dark' ? 'light' : 'dark');
        }

        (function () {
            var saved = localStorage.getItem('mcTheme') || 'light';
            applyTheme(saved);
        })();
        /* ── WHATSAPP ── */
        function toggleWA() {
            var card = document.getElementById('wa-card');
            card.style.display = (card.style.display === 'block') ? 'none' : 'block';
        }

        /* ── MOBILE NAV ── */
        function toggleMobileNav() {
            var links = document.querySelector('.nav-links');
            var open  = links.style.display === 'flex';
            links.style.display       = open ? 'none' : 'flex';
            links.style.flexDirection = 'column';
            links.style.position      = 'absolute';
            links.style.top           = '64px';
            links.style.left          = '0';
            links.style.right         = '0';
            links.style.background    = 'var(--bg-nav)';
            links.style.padding       = '20px';
            links.style.gap           = '16px';
            links.style.borderBottom  = '1px solid var(--border)';
            links.style.zIndex        = '999';
        }


                function toggleMobileNav() {
            var links   = document.querySelector('.nav-links');
            var actions = document.querySelector('.nav-actions');
            var isOpen  = links.getAttribute('data-open') === 'true';

            if (isOpen) {
                // Close
                links.removeAttribute('style');
                actions.removeAttribute('style');
                links.setAttribute('data-open', 'false');
            } else {
                // Open
                var navH = document.querySelector('.main-nav').offsetHeight;

                // Nav links
                links.style.display       = 'flex';
                links.style.flexDirection = 'column';
                links.style.position      = 'fixed';
                links.style.top           = navH + 'px';
                links.style.left          = '0';
                links.style.right         = '0';
                links.style.background    = 'var(--bg-nav)';
                links.style.padding       = '16px 20px';
                links.style.gap           = '14px';
                links.style.borderBottom  = '1px solid var(--border)';
                links.style.zIndex        = '999';
                links.style.backdropFilter = 'blur(16px)';

                // Nav actions (Sign In / Register / User info)
                actions.style.display       = 'flex';
                actions.style.flexDirection = 'column';
                actions.style.position      = 'fixed';
                actions.style.top           = (navH + links.scrollHeight + 10) + 'px';
                actions.style.left          = '0';
                actions.style.right         = '0';
                actions.style.background    = 'var(--bg-nav)';
                actions.style.padding       = '12px 20px 20px';
                actions.style.gap           = '10px';
                actions.style.borderBottom  = '1px solid var(--border)';
                actions.style.zIndex        = '999';
                actions.style.backdropFilter = 'blur(16px)';

                links.setAttribute('data-open', 'true');
            }
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>


