@{
    ViewData["Title"] = "Home";
}
<style>
    body {
        overflow-x: hidden !important;
        background: #F5F7FA !important;
    }

    /* ══ FULL-WIDTH BREAKOUT — works inside any Bootstrap container ══ */
    .fullbleed {
        width: 100vw !important;
        max-width: 100vw !important;
        position: relative !important;
        left: 50% !important;
        margin-left: -50vw !important;
        margin-right: -50vw !important;
    }

    /* ── HERO ── */
    .hero {
        position: relative;
        height: 100vh;
        min-height: 620px;
        display: flex;
        align-items: center;
        overflow: hidden;
        background: #ffffff;
    }

    /* Light slides */
    .hero-slides {
        position: absolute;
        inset: 0;
    }

    .hero-slide {
        position: absolute;
        inset: 0;
        opacity: 0;
        transition: opacity 1.5s ease;
    }

        .hero-slide.active {
            opacity: 1;
        }

    .slide-1 {
        background: linear-gradient(135deg, #f0f5ff 0%, #e8f0fd 50%, #d0e2fb 100%);
    }

    .slide-2 {
        background: linear-gradient(135deg, #eef3fc 0%, #ddeaf9 50%, #c8def7 100%);
    }

    .slide-3 {
        background: linear-gradient(135deg, #f5f7fa 0%, #e8f0fd 50%, #d5e6fb 100%);
    }

    /* Decorative soft circles */
    .deco-circle {
        position: absolute;
        border-radius: 50%;
        animation: pulse-circle 7s ease-in-out infinite;
    }

        .deco-circle:nth-child(1) {
            width: 520px;
            height: 520px;
            top: -120px;
            right: -120px;
            background: radial-gradient(circle, rgba(47,128,237,0.12) 0%, transparent 70%);
        }

        .deco-circle:nth-child(2) {
            width: 360px;
            height: 360px;
            bottom: -80px;
            left: 180px;
            animation-delay: 2s;
            background: radial-gradient(circle, rgba(30,102,208,0.08) 0%, transparent 70%);
        }

        .deco-circle:nth-child(3) {
            width: 220px;
            height: 220px;
            top: 180px;
            left: -60px;
            animation-delay: 4s;
            background: radial-gradient(circle, rgba(47,128,237,0.10) 0%, transparent 70%);
        }

    @@keyframes pulse-circle {
        0%, 100% {
            transform: scale(1);
            opacity: 0.6;
        }

        50% {
            transform: scale(1.08);
            opacity: 1;
        }
    }

    /* Floating shapes */
    .hero-shape {
        position: absolute;
        border-radius: 50%;
        animation: float-up 8s ease-in-out infinite;
        background: rgba(47,128,237,0.06);
        border: 1px solid rgba(47,128,237,0.18);
    }

        .hero-shape:nth-child(1) {
            width: 80px;
            height: 80px;
            top: 20%;
            right: 22%;
        }

        .hero-shape:nth-child(2) {
            width: 50px;
            height: 50px;
            top: 62%;
            right: 14%;
            animation-delay: 3s;
        }

        .hero-shape:nth-child(3) {
            width: 120px;
            height: 120px;
            bottom: 18%;
            right: 34%;
            animation-delay: 1.5s;
            border-radius: 24px;
        }

    @@keyframes float-up {
        0%, 100% {
            transform: translateY(0) rotate(0deg);
        }

        50% {
            transform: translateY(-18px) rotate(5deg);
        }
    }

    /* No dark overlay — light theme */
    .hero-overlay {
        position: absolute;
        inset: 0;
        background: rgba(255,255,255,0.15);
    }

    /* Right side illustration blob */
    .hero-blob {
        position: absolute;
        right: 0;
        top: 0;
        bottom: 0;
        width: 45%;
        background: linear-gradient(145deg, #ddeaf9 0%, #c0d8f5 100%);
        clip-path: ellipse(90% 100% at 100% 50%);
        opacity: 0.6;
    }

    .hero-content {
        position: relative;
        z-index: 10;
        max-width: 640px;
        padding: 0 48px;
        animation: slide-up 0.9s ease both;
    }

    @@keyframes slide-up {
        from {
            opacity: 0;
            transform: translateY(36px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #eef3fc;
        border: 1px solid #c7d7f0;
        border-radius: 100px;
        padding: 6px 16px;
        margin-bottom: 24px;
        color: #1E66D0;
        font-size: 13px;
        font-weight: 600;
        animation: slide-up 0.9s ease 0.15s both;
    }

    .badge-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #2F80ED;
        animation: blink 2s ease-in-out infinite;
    }

    @@keyframes blink {
        0%, 100% {
            opacity: 1;
        }

        50% {
            opacity: 0.3;
        }
    }

    .hero-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(34px, 4.5vw, 56px);
        color: #1a2742;
        line-height: 1.15;
        font-weight: 700;
        margin-bottom: 18px;
        animation: slide-up 0.9s ease 0.25s both;
    }

        .hero-title .accent {
            color: #1E66D0;
        }

    .hero-desc {
        color: #555555;
        font-size: 17px;
        line-height: 1.7;
        max-width: 500px;
        margin-bottom: 34px;
        animation: slide-up 0.9s ease 0.35s both;
    }

    .hero-ctas {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        animation: slide-up 0.9s ease 0.45s both;
    }

    .btn-hero-primary {
        padding: 14px 30px;
        border-radius: 10px;
        font-size: 15px;
        font-weight: 600;
        background: #2F80ED;
        color: #fff;
        border: none;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        transition: all 0.3s;
        box-shadow: 0 4px 14px rgba(47,128,237,0.3);
    }

        .btn-hero-primary:hover {
            background: #1E66D0;
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(47,128,237,0.4);
            color: #fff;
        }

    .btn-hero-outline {
        padding: 14px 30px;
        border-radius: 10px;
        font-size: 15px;
        font-weight: 500;
        background: #fff;
        border: 1.5px solid #c7d7f0;
        color: #1E66D0;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        transition: all 0.3s;
    }

        .btn-hero-outline:hover {
            border-color: #1E66D0;
            color: #1E66D0;
            background: #eef3fc;
        }

    /* Slide indicators */
    .slide-indicators {
        position: absolute;
        bottom: 32px;
        left: 48px;
        z-index: 10;
        display: flex;
        gap: 8px;
    }

    .indicator {
        width: 8px;
        height: 8px;
        border-radius: 4px;
        background: rgba(30,102,208,0.25);
        cursor: pointer;
        transition: all 0.4s;
        border: none;
    }

        .indicator.active {
            width: 28px;
            background: #1E66D0;
        }

    /* Stats bar */
    .hero-stats {
        position: absolute;
        bottom: 0;
        left: 50%;
        transform: translateX(-50%);
        background: rgba(255,255,255,0.85);
        backdrop-filter: blur(20px);
        border-top: 1px solid #dde6f5;
        border-radius: 16px 16px 0 0;
        padding: 20px 48px;
        z-index: 10;
        display: flex;
        gap: 48px;
        box-shadow: 0 -4px 24px rgba(30,102,208,0.06);
    }

    .stat-item {
        text-align: center;
    }

    .stat-num {
        font-family: 'Playfair Display', serif;
        font-size: 28px;
        color: #1E66D0;
        font-weight: 700;
        line-height: 1;
    }

    .stat-label {
        font-size: 12px;
        color: #555555;
        margin-top: 4px;
        letter-spacing: 0.4px;
    }

    /* ── HOW IT WORKS ── */
    .how-section {
        background: #F5F7FA;
        padding: 100px 40px;
        border-top: 1px solid #dde6f5;
    }

    .section-label {
        text-align: center;
        color: #1E66D0;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 3px;
        text-transform: uppercase;
        margin-bottom: 12px;
    }

    .section-title {
        font-family: 'Playfair Display', serif;
        font-size: 38px;
        color: #1a2742;
        text-align: center;
        margin-bottom: 56px;
    }

        .section-title span {
            color: #1E66D0;
        }

    .steps-grid {
        max-width: 900px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
    }

    @@media (max-width: 640px) {
        .steps-grid {
            grid-template-columns: 1fr;
        }
    }

    .step-card {
        background: #ffffff;
        border: 1px solid #dde6f5;
        border-radius: 18px;
        padding: 32px;
        position: relative;
        overflow: hidden;
        transition: all 0.3s;
        box-shadow: 0 1px 4px rgba(30,102,208,0.06);
    }

        .step-card:hover {
            border-color: #90b8f0;
            box-shadow: 0 8px 28px rgba(47,128,237,0.12);
            transform: translateY(-4px);
        }

        .step-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, transparent, #1E66D0, transparent);
            opacity: 0;
            transition: opacity 0.3s;
        }

        .step-card:hover::before {
            opacity: 1;
        }

    .step-num {
        font-family: 'Playfair Display', serif;
        font-size: 48px;
        color: rgba(30,102,208,0.10);
        font-weight: 700;
        position: absolute;
        top: 16px;
        right: 24px;
        line-height: 1;
    }

    .step-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background: #eef3fc;
        border: 1px solid #c7d7f0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        margin-bottom: 18px;
    }

    .step-title {
        color: #1a2742;
        font-size: 17px;
        font-weight: 600;
        margin-bottom: 10px;
    }

    .step-desc {
        color: #555555;
        font-size: 14px;
        line-height: 1.6;
    }
</style>

<!-- ══════════ HERO ══════════ -->
<div class="hero fullbleed">
    <div class="hero-slides">
        <div class="hero-slide slide-1 active"></div>
        <div class="hero-slide slide-2"></div>
        <div class="hero-slide slide-3"></div>
    </div>

    <div class="deco-circle"></div>
    <div class="deco-circle"></div>
    <div class="deco-circle"></div>
    <div class="hero-shape"></div>
    <div class="hero-shape"></div>
    <div class="hero-shape"></div>
    <div class="hero-overlay"></div>
    <div class="hero-blob"></div>

    <div class="hero-content">
        <div class="hero-badge">
            <div class="badge-dot"></div>
            Official Government Portal · Somalia @DateTime.UtcNow.Year
        </div>

        <h1 class="hero-title">
            Online <span class="accent">Marriage</span><br>Certificate System
        </h1>

        <p class="hero-desc">
            Submit applications securely, upload supporting documents, track review status,
            and download your official certificate as PDF once approved.
        </p>

        <div class="hero-ctas">
            <a class="btn-hero-primary" asp-controller="Account" asp-action="Register">Create Application</a>
            <a class="btn-hero-outline" asp-controller="Account" asp-action="Login">Sign In</a>
        </div>
    </div>

    <div class="slide-indicators">
        <button class="indicator active" onclick="goSlide(0)"></button>
        <button class="indicator" onclick="goSlide(1)"></button>
        <button class="indicator" onclick="goSlide(2)"></button>
    </div>

    <div class="hero-stats">
        <div class="stat-item">
            <div class="stat-num" id="stat-apps">0</div>
            <div class="stat-label">Applications</div>
        </div>
        <div class="stat-item">
            <div class="stat-num" id="stat-approved">0</div>
            <div class="stat-label">Approved</div>
        </div>
        <div class="stat-item">
            <div class="stat-num" id="stat-districts">0</div>
            <div class="stat-label">Districts</div>
        </div>
    </div>
</div>

<!-- ══════════ HOW IT WORKS ══════════ -->
<div class="how-section fullbleed">
    <p class="section-label">Process</p>
    <h2 class="section-title">How It <span>Works</span></h2>

    <div class="steps-grid">
        <div class="step-card">
            <div class="step-num">01</div>
            <div class="step-icon">👤</div>
            <div class="step-title">Register as a User</div>
            <div class="step-desc">Create your secure account to access the portal and begin your marriage certificate application.</div>
        </div>
        <div class="step-card">
            <div class="step-num">02</div>
            <div class="step-icon">📝</div>
            <div class="step-title">Complete Application</div>
            <div class="step-desc">Fill in full spouse and ceremony details, then upload all required supporting documents securely.</div>
        </div>
        <div class="step-card">
            <div class="step-num">03</div>
            <div class="step-icon">✅</div>
            <div class="step-title">Staff Review</div>
            <div class="step-desc">Our trained staff review your submission and either approve it or provide remarks for revision.</div>
        </div>
        <div class="step-card">
            <div class="step-num">04</div>
            <div class="step-icon">📄</div>
            <div class="step-title">Download Certificate</div>
            <div class="step-desc">After approval, instantly download your official marriage certificate as a verified PDF document.</div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let current = 0;
        const slides = document.querySelectorAll('.hero-slide');
        const indicators = document.querySelectorAll('.indicator');

        function goSlide(n) {
            slides[current].classList.remove('active');
            indicators[current].classList.remove('active');
            current = n;
            slides[current].classList.add('active');
            indicators[current].classList.add('active');
        }
        setInterval(() => goSlide((current + 1) % slides.length), 4500);

        function countUp(el, target, duration) {
            let start = 0;
            const step = target / (duration / 16);
            const timer = setInterval(() => {
                start += step;
                if (start >= target) { el.textContent = target; clearInterval(timer); return; }
                el.textContent = Math.floor(start);
            }, 16);
        }
        setTimeout(() => {
            countUp(document.getElementById('stat-apps'),     2847, 2000);
            countUp(document.getElementById('stat-approved'), 2310, 2000);
            countUp(document.getElementById('stat-districts'),  18, 1500);
        }, 600);
    </script>
}
