@{
    ViewData["Title"] = "About";
}

<style>
    :root {
        --primary: #1E66D0;
        --primary-dark: #1757b8;
        --primary-light: #e8f0fc;
        --btn-blue: #2F80ED;
        --bg: #F5F7FA;
        --bg-white: #ffffff;
        --text-dark: #333333;
        --text-mid: #555555;
        --text-muted: #888888;
        --border: #e2e8f0;
        --shadow-sm: 0 1px 4px rgba(0,0,0,0.07);
        --shadow-md: 0 4px 18px rgba(30,102,208,0.12);
    }

    body {
        background: var(--bg) !important;
        color: var(--text-dark) !important;
        overflow-x: hidden !important;
    }

    .fullbleed {
        width: 100vw !important;
        max-width: 100vw !important;
        position: relative !important;
        left: 50% !important;
        margin-left: -50vw !important;
        margin-right: -50vw !important;
    }

    /* ── PAGE HERO ── */
    .page-hero {
        background: linear-gradient(135deg, #f0f5ff 0%, #e8f0fc 60%, #dbeafe 100%);
        padding: 80px 40px 60px;
        text-align: center;
        position: relative;
        overflow: hidden;
        border-bottom: 1px solid var(--border);
    }

        .page-hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 30% 50%, rgba(30,102,208,0.08) 0%, transparent 60%);
        }

    .page-hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: var(--primary-light);
        border: 1px solid rgba(30,102,208,0.2);
        border-radius: 100px;
        padding: 5px 14px;
        margin-bottom: 20px;
        color: var(--primary);
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    .page-hero h1 {
        font-family: 'Playfair Display', serif;
        font-size: clamp(32px, 4vw, 48px);
        color: var(--text-dark);
        font-weight: 700;
        margin-bottom: 14px;
        position: relative;
    }

        .page-hero h1 span {
            color: var(--primary);
        }

    .page-hero p {
        color: var(--text-mid);
        font-size: 17px;
        line-height: 1.65;
        max-width: 560px;
        margin: 0 auto;
        position: relative;
    }

    /* ── MISSION SECTION ── */
    .mission-section {
        background: var(--bg-white);
        padding: 80px 40px;
        border-bottom: 1px solid var(--border);
    }

    .mission-inner {
        max-width: 1000px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        align-items: center;
    }

    @@media (max-width: 768px) {
        .mission-inner {
            grid-template-columns: 1fr;
            gap: 36px;
        }
    }

    .mission-text .section-label {
        text-align: left;
        margin-bottom: 10px;
    }

    .mission-text h2 {
        font-family: 'Playfair Display', serif;
        font-size: 34px;
        color: var(--text-dark);
        font-weight: 700;
        margin-bottom: 16px;
        line-height: 1.2;
    }

        .mission-text h2 span {
            color: var(--primary);
        }

    .mission-text p {
        color: var(--text-mid);
        font-size: 15px;
        line-height: 1.75;
        margin-bottom: 14px;
    }

    .mission-visual {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    .mv-card {
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 24px 20px;
        text-align: center;
        transition: all 0.3s;
    }

        .mv-card:hover {
            border-color: rgba(30,102,208,0.3);
            box-shadow: var(--shadow-md);
            transform: translateY(-3px);
        }

    .mv-icon {
        font-size: 28px;
        margin-bottom: 10px;
    }

    .mv-num {
        font-family: 'Playfair Display', serif;
        font-size: 28px;
        color: var(--primary);
        font-weight: 700;
        line-height: 1;
    }

    .mv-label {
        font-size: 12px;
        color: var(--text-muted);
        margin-top: 4px;
    }

    /* ── VALUES ── */
    .values-section {
        background: var(--bg);
        padding: 80px 40px;
        border-bottom: 1px solid var(--border);
    }

    .section-label {
        text-align: center;
        color: var(--primary);
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 3px;
        text-transform: uppercase;
        margin-bottom: 10px;
    }

    .section-title {
        font-family: 'Playfair Display', serif;
        font-size: 36px;
        color: var(--text-dark);
        text-align: center;
        margin-bottom: 50px;
    }

        .section-title span {
            color: var(--primary);
        }

    .values-grid {
        max-width: 960px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
    }

    @@media (max-width: 768px) {
        .values-grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    @@media (max-width: 480px) {
        .values-grid {
            grid-template-columns: 1fr;
        }
    }

    .value-card {
        background: var(--bg-white);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 28px 24px;
        transition: all 0.3s;
        box-shadow: var(--shadow-sm);
        position: relative;
        overflow: hidden;
    }

        .value-card:hover {
            border-color: rgba(30,102,208,0.3);
            box-shadow: var(--shadow-md);
            transform: translateY(-4px);
        }

        .value-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, transparent, var(--primary), transparent);
            opacity: 0;
            transition: opacity 0.3s;
        }

        .value-card:hover::before {
            opacity: 1;
        }

    .value-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background: var(--primary-light);
        border: 1px solid rgba(30,102,208,0.15);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        margin-bottom: 16px;
    }

    .value-title {
        color: var(--text-dark);
        font-size: 16px;
        font-weight: 600;
        margin-bottom: 8px;
    }

    .value-desc {
        color: var(--text-mid);
        font-size: 13px;
        line-height: 1.6;
    }

    /* ── TEAM ── */
    .team-section {
        background: var(--bg-white);
        padding: 80px 40px;
        border-bottom: 1px solid var(--border);
    }

    .team-grid {
        max-width: 900px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
    }

    @@media (max-width: 768px) {
        .team-grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    @@media (max-width: 480px) {
        .team-grid {
            grid-template-columns: 1fr;
        }
    }

    .team-card {
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 28px 20px;
        text-align: center;
        transition: all 0.3s;
        box-shadow: var(--shadow-sm);
    }

        .team-card:hover {
            border-color: rgba(30,102,208,0.25);
            box-shadow: var(--shadow-md);
            transform: translateY(-4px);
        }

    .team-avatar {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        margin: 0 auto 14px;
        background: linear-gradient(135deg, var(--primary-light), #bfdbfe);
        border: 3px solid var(--primary-light);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
    }

    .team-name {
        color: var(--text-dark);
        font-size: 15px;
        font-weight: 700;
        margin-bottom: 4px;
    }

    .team-role {
        color: var(--primary);
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.3px;
        margin-bottom: 10px;
    }

    .team-desc {
        color: var(--text-muted);
        font-size: 13px;
        line-height: 1.55;
    }

    /* ── CTA ── */
    .cta-section {
        background: linear-gradient(135deg, var(--primary) 0%, #2F80ED 100%);
        padding: 70px 40px;
        text-align: center;
    }

        .cta-section h2 {
            font-family: 'Playfair Display', serif;
            font-size: 34px;
            color: #fff;
            font-weight: 700;
            margin-bottom: 14px;
        }

        .cta-section p {
            color: rgba(255,255,255,0.8);
            font-size: 16px;
            margin-bottom: 32px;
        }

    .cta-btns {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 12px;
    }

    .btn-cta {
        padding: 14px 36px;
        border-radius: 10px;
        font-size: 15px;
        font-weight: 600;
        background: #fff;
        color: var(--primary);
        border: none;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s;
        box-shadow: 0 4px 18px rgba(0,0,0,0.15);
    }

        .btn-cta:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 28px rgba(0,0,0,0.2);
            color: var(--primary);
        }

    .btn-cta-outline {
        padding: 14px 36px;
        border-radius: 10px;
        font-size: 15px;
        font-weight: 500;
        background: transparent;
        color: #fff;
        border: 1.5px solid rgba(255,255,255,0.5);
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        transition: all 0.3s;
    }

        .btn-cta-outline:hover {
            background: rgba(255,255,255,0.1);
            color: #fff;
            border-color: #fff;
        }
</style>

<!-- PAGE HERO -->
<div class="page-hero fullbleed">
    <div class="page-hero-badge">ℹ️ &nbsp; About Us</div>
    <h1>About the <span>System</span></h1>
    <p>Learn about the Online Marriage Certificate Information Management System — built to modernize and simplify official marriage registration in Somalia.</p>
</div>

<!-- MISSION -->
<div class="mission-section fullbleed">
    <div class="mission-inner">
        <div class="mission-text">
            <p class="section-label">OUR MISSION</p>
            <h2>Digitizing <span>Civil Registration</span> in Somalia</h2>
            <p>
                The Online Marriage Certificate System was established to eliminate the inefficiencies
                of paper-based processes and bring official marriage registration fully online —
                accessible to all citizens regardless of location.
            </p>
            <p>
                Our platform connects applicants directly with authorized officials, ensuring
                fast, transparent, and legally valid processing of every marriage certificate request.
            </p>
        </div>
        <div class="mission-visual">
            <div class="mv-card">
                <div class="mv-icon">📋</div>
                <div class="mv-num">2,847</div>
                <div class="mv-label">Applications</div>
            </div>
            <div class="mv-card">
                <div class="mv-icon">✅</div>
                <div class="mv-num">2,310</div>
                <div class="mv-label">Approved</div>
            </div>
            <div class="mv-card">
                <div class="mv-icon">🗺️</div>
                <div class="mv-num">18</div>
                <div class="mv-label">Districts</div>
            </div>
            <div class="mv-card">
                <div class="mv-icon">⚡</div>
                <div class="mv-num">48h</div>
                <div class="mv-label">Avg. Review</div>
            </div>
        </div>
    </div>
</div>

<!-- VALUES -->
<div class="values-section fullbleed">
    <p class="section-label">What We Stand For</p>
    <h2 class="section-title">Our Core <span>Values</span></h2>

    <div class="values-grid">
        <div class="value-card">
            <div class="value-icon">🔒</div>
            <div class="value-title">Security & Privacy</div>
            <div class="value-desc">All personal data and uploaded documents are stored securely and never shared without authorization.</div>
        </div>
        <div class="value-card">
            <div class="value-icon">⚡</div>
            <div class="value-title">Speed & Efficiency</div>
            <div class="value-desc">Applications are processed within 48 hours. No waiting in queues or making repeated office visits.</div>
        </div>
        <div class="value-card">
            <div class="value-icon">🌍</div>
            <div class="value-title">Accessibility</div>
            <div class="value-desc">Available to all citizens across Somalia — from major cities to remote districts — via any device.</div>
        </div>
        <div class="value-card">
            <div class="value-icon">📊</div>
            <div class="value-title">Transparency</div>
            <div class="value-desc">Track every step of your application in real-time. No hidden processes or unclear decisions.</div>
        </div>
        <div class="value-card">
            <div class="value-icon">⚖️</div>
            <div class="value-title">Legal Validity</div>
            <div class="value-desc">All certificates issued through this system are officially recognized and legally valid documents.</div>
        </div>
        <div class="value-card">
            <div class="value-icon">🤝</div>
            <div class="value-title">Citizen Support</div>
            <div class="value-desc">Dedicated support team available via WhatsApp to assist with any questions or application issues.</div>
        </div>
    </div>
</div>

<!-- TEAM -->
<div class="team-section fullbleed">
    <p class="section-label">The Team</p>
    <h2 class="section-title">Who <span>Built This</span></h2>

    <div class="team-grid">
        <div class="team-card">
            <div class="team-avatar">👨‍💼</div>
            <div class="team-name">System Administrator</div>
            <div class="team-role">Platform Manager</div>
            <div class="team-desc">Oversees all operations, manages staff accounts, and ensures the system runs efficiently.</div>
        </div>
        <div class="team-card">
            <div class="team-avatar">👩‍⚖️</div>
            <div class="team-name">Review Officers</div>
            <div class="team-role">Application Reviewers</div>
            <div class="team-desc">Trained officials who verify submitted applications and issue official approvals or revision requests.</div>
        </div>
        <div class="team-card">
            <div class="team-avatar">💻</div>
            <div class="team-name">Technical Team</div>
            <div class="team-role">Developers & Support</div>
            <div class="team-desc">Maintains the platform, ensures uptime, and continuously improves the user experience.</div>
        </div>
    </div>
</div>

<!-- CTA -->
<div class="cta-section fullbleed">
    <h2>Join Thousands of Citizens</h2>
    <p>Start your marriage certificate application today — it only takes a few minutes.</p>
    <div class="cta-btns">
        <a class="btn-cta" asp-controller="Account" asp-action="Register">
            <i class="fa fa-user-plus"></i> Create Account
        </a>
        <a class="btn-cta-outline" asp-controller="Home" asp-action="Index">
            <i class="fa fa-home"></i> Back to Home
        </a>
    </div>
</div>
