@{
    ViewData["Title"] = "Dashboard";
}

<style>
    /* ── DASHBOARD PAGE ── */
    .dash-wrap {
        min-height: calc(100vh - 72px);
        padding: 48px 0 64px;
    }

    /* ── WELCOME HEADER ── */
    .dash-header {
        margin-bottom: 40px;
        text-align:center;
    }

    .dash-greeting {
        font-size: 13px;
        font-weight: 600;
        color: #2F80ED;
        letter-spacing: 2.5px;
        text-transform: uppercase;
        margin-bottom: 8px;
    }

    .dash-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(28px, 3.5vw, 42px);
        color: #1a2742;
        font-weight: 700;
        margin: 0;
        line-height: 1.2;
    }

        .dash-title span {
            color: #2F80ED;
        }

    .dash-subtitle {
        color: #555555;
        font-size: 15px;
        margin-top: 10px;
    }

    /* ── STAT CARDS ── */
    .stat-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 40px;
    }
    @@media (max-width: 900px) {
        .stat-grid

    {
        grid-template-columns: repeat(2,1fr);
    }

    }
    @@media (max-width: 500px) {
        .stat-grid

    {
        grid-template-columns: 1fr;
    }

    }

    .stat-card {
        background: #fff;
        border-radius: 20px;
        padding: 28px 24px;
        position: relative;
        overflow: hidden;
        box-shadow: 0 2px 16px rgba(30,102,208,0.07);
        border: 1px solid #e8eef8;
        transition: all 0.3s ease;
        animation: card-in 0.6s ease both;
    }

        .stat-card:nth-child(1) {
            animation-delay: 0.05s;
        }

        .stat-card:nth-child(2) {
            animation-delay: 0.12s;
        }

        .stat-card:nth-child(3) {
            animation-delay: 0.19s;
        }

        .stat-card:nth-child(4) {
            animation-delay: 0.26s;
        }

    @@keyframes card-in {
        from

    {
        opacity: 0;
        transform: translateY(20px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 32px rgba(30,102,208,0.13);
        border-color: #c7d7f0;
    }

    /* Top accent bar */
    .stat-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        border-radius: 20px 20px 0 0;
    }

    .stat-card.c-pending::before {
        background: #94a3b8;
    }

    .stat-card.c-review::before {
        background: #f59e0b;
    }

    .stat-card.c-approved::before {
        background: #10b981;
    }

    .stat-card.c-rejected::before {
        background: #ef4444;
    }

    /* Glow blob */
    .stat-card::after {
        content: '';
        position: absolute;
        width: 120px;
        height: 120px;
        border-radius: 50%;
        right: -30px;
        bottom: -30px;
        opacity: 0.06;
        transition: opacity 0.3s;
    }

    .stat-card.c-pending::after {
        background: #94a3b8;
    }

    .stat-card.c-review::after {
        background: #f59e0b;
    }

    .stat-card.c-approved::after {
        background: #10b981;
    }

    .stat-card.c-rejected::after {
        background: #ef4444;
    }

    .stat-card:hover::after {
        opacity: 0.12;
    }

    .stat-icon {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        margin-bottom: 20px;
    }

    .stat-card.c-pending .stat-icon {
        background: #f1f5f9;
        color: #64748b;
    }

    .stat-card.c-review .stat-icon {
        background: #fffbeb;
        color: #d97706;
    }

    .stat-card.c-approved .stat-icon {
        background: #ecfdf5;
        color: #059669;
    }

    .stat-card.c-rejected .stat-icon {
        background: #fef2f2;
        color: #dc2626;
    }

    .stat-label {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        margin-bottom: 10px;
    }

    .stat-card.c-pending .stat-label {
        color: #94a3b8;
    }

    .stat-card.c-review .stat-label {
        color: #f59e0b;
    }

    .stat-card.c-approved .stat-label {
        color: #10b981;
    }

    .stat-card.c-rejected .stat-label {
        color: #ef4444;
    }

    .stat-number {
        font-family: 'Playfair Display', serif;
        font-size: 48px;
        font-weight: 700;
        line-height: 1;
        color: #1a2742;
        margin: 0;
    }

    .stat-trend {
        font-size: 12px;
        color: #94a3b8;
        margin-top: 10px;
    }

    /* ── DIVIDER ── */
    .dash-divider {
        height: 1px;
        background: linear-gradient(90deg, transparent, #dde6f5, transparent);
        margin: 8px 0 36px;
    }

    /* ── ACTION SECTION ── */
    .action-section {
        animation: card-in 0.6s ease 0.35s both;
    }

    .action-label {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: #94a3b8;
        margin-bottom: 16px;
    }

    .action-row {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        align-items: center;
    }

    .btn-dash-primary {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 14px 28px;
        background: #2F80ED;
        color: #fff;
        border: none;
        border-radius: 12px;
        font-size: 14px;
        font-weight: 600;
        font-family: 'DM Sans', sans-serif;
        text-decoration: none;
        cursor: pointer;
        transition: all 0.25s;
        box-shadow: 0 4px 14px rgba(47,128,237,0.30);
    }

        .btn-dash-primary:hover {
            background: #1E66D0;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(47,128,237,0.40);
            color: #fff;
        }

        .btn-dash-primary .btn-icon {
            width: 28px;
            height: 28px;
            background: rgba(255,255,255,0.2);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            flex-shrink: 0;
        }

    .btn-dash-outline {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 14px 28px;
        background: #fff;
        color: #1E66D0;
        border: 1.5px solid #c7d7f0;
        border-radius: 12px;
        font-size: 14px;
        font-weight: 500;
        font-family: 'DM Sans', sans-serif;
        text-decoration: none;
        cursor: pointer;
        transition: all 0.25s;
    }

        .btn-dash-outline:hover {
            background: #eef3fc;
            border-color: #1E66D0;
            color: #1E66D0;
            transform: translateY(-2px);
        }

    /* ── QUICK INFO BANNER ── */
    .info-banner {
        margin-top: 36px;
        background: linear-gradient(135deg, #eef3fc 0%, #ddeaf9 100%);
        border: 1px solid #c7d7f0;
        border-radius: 16px;
        padding: 20px 24px;
        display: flex;
        align-items: center;
        gap: 16px;
        animation: card-in 0.6s ease 0.45s both;
    }

    .info-banner-icon {
        width: 40px;
        height: 40px;
        background: #2F80ED;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 18px;
        flex-shrink: 0;
    }

    .info-banner-text strong {
        display: block;
        color: #1a2742;
        font-size: 14px;
        font-weight: 600;
        margin-bottom: 2px;
    }

    .info-banner-text span {
        color: #555555;
        font-size: 13px;
    }
</style>

<div class="dash-wrap">

    <!-- HEADER -->
    <div class="dash-header">
        @* <p class="dash-greeting">📋 My Dashboard</p> *@
        <h1 class="dash-title">Welcome <span>back</span></h1>
        <p class="dash-subtitle">Here's an overview of your marriage certificate applications.</p>
    </div>

    <!-- STAT CARDS -->
    <div class="stat-grid">

        <!-- Pending Payment -->
        <div class="stat-card c-pending">
            <div class="stat-icon"><i class="fas fa-clock"></i></div>
            <div class="stat-label">Pending Payment</div>
            <p class="stat-number">@ViewBag.PendingPayment</p>
            <div class="stat-trend">Awaiting payment confirmation</div>
        </div>

        <!-- Pending Review -->
        <div class="stat-card c-review">
            <div class="stat-icon"><i class="fas fa-hourglass-half"></i></div>
            <div class="stat-label">Pending Review</div>
            <p class="stat-number">@ViewBag.Pending</p>
            <div class="stat-trend">Under staff review</div>
        </div>

        <!-- Approved -->
        <div class="stat-card c-approved">
            <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
            <div class="stat-label">Approved</div>
            <p class="stat-number">@ViewBag.Approved</p>
            <div class="stat-trend">Ready to download</div>
        </div>

        <!-- Rejected -->
        <div class="stat-card c-rejected">
            <div class="stat-icon"><i class="fas fa-times-circle"></i></div>
            <div class="stat-label">Rejected</div>
            <p class="stat-number">@ViewBag.Rejected</p>
            <div class="stat-trend">Requires revision</div>
        </div>

    </div>

    <!-- DIVIDER -->
    <div class="dash-divider"></div>

    <!-- ACTIONS -->
    <div class="action-section">
        <p class="action-label">Quick Actions</p>
        <div class="action-row">
            <a class="btn-dash-primary" asp-controller="Applications" asp-action="Create">
                <span class="btn-icon"><i class="fas fa-plus"></i></span>
                New marriage application
            </a>
            <a class="btn-dash-outline" asp-controller="Applications" asp-action="Index">
                <i class="fas fa-list"></i>
                View all applications
            </a>
        </div>
    </div>

    <!-- INFO BANNER -->
    <div class="info-banner">
        <div class="info-banner-icon"><i class="fas fa-info"></i></div>
        <div class="info-banner-text">
            <strong>Need help with your application?</strong>
            <span>Contact our support team via WhatsApp or check the application guidelines.</span>
        </div>
    </div>

</div>
