@model online_mr_certi.Models.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
}

<style>
    :root {
        --primary: #1E66D0;
        --primary-dark: #1757b8;
        --primary-light: #e8f0fc;
        --btn-blue: #2F80ED;
        --bg: #F5F7FA;
        --bg-white: #ffffff;
        --text-dark: #333333;
        --text-mid: #555555;
        --text-muted: #888888;
        --border: #e2e8f0;
        --danger: #dc2626;
        --danger-light: #fef2f2;
    }

    body {
        background: var(--bg) !important;
    }

    .auth-wrapper {
        min-height: calc(100vh - 140px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 16px;
    }

    .auth-card {
        width: 100%;
        max-width: 440px;
        background: var(--bg-white);
        border: 1px solid var(--border);
        border-radius: 20px;
        box-shadow: 0 4px 24px rgba(30,102,208,0.08);
        overflow: hidden;
    }

    .auth-card-top {
        height: 4px;
        background: linear-gradient(90deg, var(--primary), var(--btn-blue));
    }

    .auth-card-body {
        padding: 40px 36px;
    }

    .auth-icon {
        width: 56px;
        height: 56px;
        border-radius: 14px;
        background: var(--primary-light);
        border: 1px solid rgba(30,102,208,0.15);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        margin-bottom: 20px;
    }

    .auth-title {
        font-family: 'Playfair Display', serif;
        font-size: 26px;
        font-weight: 700;
        color: var(--text-dark);
        margin-bottom: 6px;
    }

    .auth-subtitle {
        font-size: 14px;
        color: var(--text-muted);
        margin-bottom: 28px;
    }

    .auth-label {
        font-size: 13px;
        font-weight: 600;
        color: var(--text-dark);
        margin-bottom: 6px;
        display: block;
    }

    .auth-input {
        width: 100%;
        padding: 11px 14px;
        border: 1.5px solid var(--border);
        border-radius: 10px;
        font-size: 14px;
        font-family: 'DM Sans', sans-serif;
        color: var(--text-dark);
        background: var(--bg);
        transition: all 0.2s;
        outline: none;
    }

        .auth-input:focus {
            border-color: var(--primary);
            background: var(--bg-white);
            box-shadow: 0 0 0 3px rgba(30,102,208,0.1);
        }

    .field-error {
        font-size: 12px;
        color: var(--danger);
        margin-top: 5px;
        display: block;
    }

    .field-group {
        margin-bottom: 20px;
    }

    .btn-auth {
        width: 100%;
        padding: 13px;
        border-radius: 10px;
        font-size: 15px;
        font-weight: 600;
        background: var(--btn-blue);
        color: #fff;
        border: none;
        cursor: pointer;
        font-family: 'DM Sans', sans-serif;
        transition: all 0.3s;
        box-shadow: 0 4px 14px rgba(47,128,237,0.3);
        margin-top: 4px;
    }

        .btn-auth:hover {
            background: var(--primary-dark);
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(47,128,237,0.4);
        }

    .auth-footer {
        text-align: center;
        margin-top: 22px;
        font-size: 13px;
        color: var(--text-muted);
    }

        .auth-footer a {
            color: var(--primary);
            font-weight: 600;
            text-decoration: none;
        }

            .auth-footer a:hover {
                text-decoration: underline;
            }
</style>

<div class="auth-wrapper">
    <div class="auth-card">
        @* <div class="auth-card-top"></div> *@
        <div class="auth-card-body">
            @* <div class="auth-icon">📧</div> *@
            <h1 class="auth-title">Forgot password?</h1>
            <p class="auth-subtitle">Enter your email below and we'll send a secure password reset link to your inbox.</p>

            <form asp-action="ForgotPassword" method="post">
                <div class="field-group">
                    <label asp-for="Email" class="auth-label">Email address</label>
                    <input asp-for="Email" class="auth-input" placeholder="you@example.com" autocomplete="email" />
                    <span asp-validation-for="Email" class="field-error"></span>
                </div>

                <button type="submit" class="btn-auth">
                    <i class="fa fa-paper-plane" style="margin-right:6px"></i> Send Reset Link
                </button>
            </form>
            <p class="auth-footer">
                Remembered it? <a asp-action="Login">Sign in instead</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}