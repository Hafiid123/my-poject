@model List<online_mr_certi.Models.MarriageApplication>
@using online_mr_certi.Models
@{
    ViewData["Title"] = "Applications";
    var q = ViewBag.Query as string;
    var st = ViewBag.StatusFilter as string;
}

<div class="card card-outline card-primary mb-3">
    <div class="card-body">
        <form method="get" class="form-row align-items-end">
            <div class="form-group col-md-4">
                <label>Search</label>
                <input class="form-control" name="q" value="@q" placeholder="Name, email, or application ID" />
            </div>
            <div class="form-group col-md-3">
                <label>Status</label>
                <select class="form-control" name="status">
                    <option value="">All</option>
                    @if (st == ApplicationStatus.PendingPayment)
                    {
                        <option value="@ApplicationStatus.PendingPayment" selected>Pending Payment</option>
                    }
                    else
                    {
                        <option value="@ApplicationStatus.PendingPayment">Pending Payment</option>
                    }
                    @if (st == ApplicationStatus.Pending)
                    {
                        <option value="@ApplicationStatus.Pending" selected>Pending</option>
                    }
                    else
                    {
                        <option value="@ApplicationStatus.Pending">Pending</option>
                    }
                    @if (st == ApplicationStatus.Approved)
                    {
                        <option value="@ApplicationStatus.Approved" selected>Approved</option>
                    }
                    else
                    {
                        <option value="@ApplicationStatus.Approved">Approved</option>
                    }
                    @if (st == ApplicationStatus.Rejected)
                    {
                        <option value="@ApplicationStatus.Rejected" selected>Rejected</option>
                    }
                    else
                    {
                        <option value="@ApplicationStatus.Rejected">Rejected</option>
                    }
                </select>
            </div>
            <div class="form-group col-md-2">
                <button type="submit" class="btn btn-primary btn-block">Filter</button>
            </div>

   

        </form>
    </div>
</div>

<div class="card">
    <div class="card-header"><h3 class="card-title">Applications (@Model.Count)</h3>
        <div class="d-flex justify-content-end mb-2 px-2">
            <a asp-action="CreateApplication" asp-controller="Admin"
               class="btn btn-primary me-5">
                <i class="fas fa-user-plus"></i> Create New Application
            </a>
        </div>
    </div>

    <div class="card-body table-responsive p-0">
        <table class="table table-striped mb-0">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Applicant</th>
                    <th>Parties</th>
                    <th>Marriage Date</th>
                    <th>Status</th>
                    <th>Submitted</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model)
                {
                    <tr>
                        <td>@a.Id</td>
                        <td>@a.User.Name</td>
                        <td>@a.HusbandName &amp; @a.WifeName</td>
                        <td>@a.MarriageDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            @if (a.Status == ApplicationStatus.PendingPayment)
                            { <span class="badge badge-secondary">Pending Payment</span> }
                            else if (a.Status == ApplicationStatus.Pending)
                            { <span class="badge badge-warning">Pending</span> }
                            else if (a.Status == ApplicationStatus.Approved)
                            { <span class="badge badge-success">Approved</span> }
                            else
                            { <span class="badge badge-danger">Rejected</span> }
                        </td>
                        <td>@a.SubmissionDate.ToString("yyyy-MM-dd")</td>
                        <td class="text-nowrap">
                            <a asp-action="ApplicationDetails" asp-route-id="@a.Id"
                               class="btn btn-sm btn-warning me-1" title="View">
                                <i class="fas fa-eye"></i>
                            </a>

                            <a asp-action="EditApplication" asp-route-id="@a.Id"
                               class="btn btn-sm btn-info me-1" title="Edit">
                                <i class="fas fa-edit"></i>
                            </a>

                            <form asp-action="DeleteApplicationConfirmed" asp-controller="Admin" asp-route-id="@a.Id"
                                  method="post" style="display:inline;"
                                  onsubmit="return confirm('Ma hubtaa inaad tirtirto codsigan #@a.Id?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-danger">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>

                            @if (a.Status == ApplicationStatus.Approved)
                            {
                                <a asp-controller="Admin" asp-action="PrintCertificate" asp-route-id="@a.Id"
                                   class="btn btn-sm btn-secondary" target="_blank">
                                    <i class="fas fa-print"></i> Print
                                </a>
                            }
                        </td>
                        
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
