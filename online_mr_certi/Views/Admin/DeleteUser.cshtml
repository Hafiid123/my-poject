@model online_mr_certi.Models.User
@{
    ViewData["Title"] = "Delete User";
    var appCount = (int)(ViewBag.ApplicationCount ?? 0);
}

<div class="card card-danger card-outline">
    <div class="card-header"><h3 class="card-title">Delete user #@Model.Id</h3></div>
    <div class="card-body">
        <p>Are you sure you want to delete this user?</p>
        <ul class="mb-3">
            <li><strong>Name:</strong> @Model.Name</li>
            <li><strong>Email:</strong> @Model.Email</li>
            <li><strong>Role:</strong> @Model.Role</li>
            <li><strong>Applications:</strong> @appCount</li>
        </ul>
        @if (appCount > 0)
        {
            <div class="alert alert-warning mb-0">
                This user has applications and cannot be deleted.
            </div>
        }
    </div>
    <div class="card-footer">
        @if (appCount == 0)
        {
            <form asp-action="DeleteUserConfirmed" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn btn-danger">Delete user</button>
            </form>
        }
        <a asp-action="Users" class="btn btn-default">Back</a>
    </div>
</div>
