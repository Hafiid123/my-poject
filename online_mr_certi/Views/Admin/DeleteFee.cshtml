@model online_mr_certi.Models.Fee
@{
    ViewData["Title"] = "Delete Fee";
    var paymentCount = ViewBag.PaymentsReferencingFee as int? ?? 0;
    var canDelete = paymentCount == 0;
}
<div class="card card-danger card-outline">
    <div class="card-header"><h3 class="card-title">Delete fee #@Model.Id</h3></div>
    <div class="card-body">
        <p>Are you sure you want to delete this fee?</p>
        <ul class="mb-3">
            <li><strong>Service:</strong> @Model.ServiceName</li>
            <li><strong>Amount:</strong> @Model.Amount.ToString("N2") @Model.Currency</li>
            <li><strong>Active:</strong> @(Model.IsActive ? "Yes" : "No")</li>
        </ul>

        @if (!canDelete)
        {
            <div class="alert alert-warning mb-0">
                <strong>Cannot delete:</strong> This fee is linked to <strong>@paymentCount</strong> payment record(s).
                Historical payments keep their fee reference for auditing.
                Turn off <strong>Active</strong> on <a asp-action="EditFee" asp-route-id="@Model.Id">Edit fee</a> if you no longer want new applications to use it.
            </div>
        }
        else
        {
            <p class="text-muted small mb-0">No payments reference this fee. New applications still require at least one active fee elsewhere.</p>
        }
    </div>
    <div class="card-footer">
        @if (canDelete)
        {
            <form asp-action="DeleteFeeConfirmed" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn btn-danger">Delete permanently</button>
            </form>
        }
        <a asp-action="FeesSettings" class="btn btn-default @(canDelete ? "" : "btn-primary")">@(canDelete ? "Cancel" : "Back to fees")</a>
    </div>
</div>
