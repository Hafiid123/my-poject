@model online_mr_certi.Models.MarriageApplication
@{
    ViewData["Title"] = "Delete Application";
}

<div class="card card-danger card-outline">
    <div class="card-header"><h3 class="card-title">Delete application #@Model.Id</h3></div>
    <div class="card-body">
        <p>Are you sure you want to delete this application?</p>
        <ul class="mb-0">
            <li><strong>Applicant:</strong> @Model.User.Name (@Model.User.Email)</li>
            <li><strong>Parties:</strong> @Model.HusbandName &amp; @Model.WifeName</li>
            <li><strong>Status:</strong> @Model.Status</li>
            <li><strong>Submitted:</strong> @Model.SubmissionDate.ToString("yyyy-MM-dd HH:mm") UTC</li>
        </ul>
    </div>
    <div class="card-footer">
        <form asp-action="DeleteApplicationConfirmed" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="btn btn-danger">Delete application</button>
        </form>
        <a asp-action="ApplicationDetails" asp-route-id="@Model.Id" class="btn btn-default">Cancel</a>
    </div>
</div>
