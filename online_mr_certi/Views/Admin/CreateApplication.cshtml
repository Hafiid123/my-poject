@model online_mr_certi.Models.ViewModels.MarriageApplicationCreateViewModel
@{
    ViewData["Title"] = "New Marriage Application";
}

@* <div class="row mb-3">
    <div class="col-sm-6">
        <h4 class="m-0">
            <i class="fas fa-file-contract mr-2 text-primary"></i> New Marriage Application
        </h4>
    </div>
    <div class="col-sm-6">
        <ol class="breadcrumb float-sm-right">
            <li class="breadcrumb-item"><a asp-action="Index">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Applications">Applications</a></li>
            <li class="breadcrumb-item active">New</li>
        </ol>
