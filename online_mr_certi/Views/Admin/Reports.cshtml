@model ReportsViewModel
@using online_mr_certi.Models
@{
    ViewData["Title"] = "Reports";
}

<div class="card card-outline card-primary mb-3">
    <div class="card-body">
        <form method="get" class="form-row align-items-end">
            <div class="form-group col-md-4">
                <label>Search</label>
                <input class="form-control" id="searchBox" placeholder="Name, status, ref..." />
            </div>
            <div class="form-group col-md-3">
                <label>Status</label>
                <select class="form-control" id="statusFilter">
                    <option value="">All</option>
                    <option value="Approved">Approved</option>
                    <option value="Pending">Pending</option>
                    <option value="Rejected">Rejected</option>
                </select>
            </div>
            <div class="form-group col-md-2">
                <label>Show</label>
                <select class="form-control" id="perPage">
                    <option value="5">5</option>
                    <option value="10" selected>10</option>
                    <option value="25">25</option>
                    <option value="9999">All</option>
                </select>
            </div>
            <div class="form-group col-md-2">
                <button type="button" class="btn btn-primary btn-block" onclick="renderTable()">Filter</button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h3 class="card-title">Marriage Applications Report (<span id="totalCount">0</span>)</h3>
        <div class="d-flex justify-content-end mb-2 px-2 gap-2">
            <button type="button" class="btn btn-info mr-2" onclick="printReport()">
                <i class="fas fa-print"></i> Print
            </button>
            <a href="@Url.Action("ReportsCsv","Admin")" class="btn btn-success me-5">
                <i class="fas fa-download"></i> Download CSV
            </a>
        </div>
    </div>

    <div class="card-body table-responsive p-0">
        <table class="table table-striped mb-0" id="mainTable">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Ref No</th>
                    <th>Husband</th>
                    <th>Wife</th>
                    <th>Amount</th>
                    <th>Payment</th>
                    <th>Status</th>
                    <th>Date</th>
                </tr>
            </thead>
            <tbody id="tBody">
                <tr><td colspan="8" class="text-center text-muted py-4">Loading...</td></tr>
            </tbody>
        </table>
    </div>

    <div class="card-footer clearfix">
        <span id="infoText" class="float-left text-muted" style="font-size:13px;"></span>
        <ul class="pagination pagination-sm m-0 float-right" id="pageNums"></ul>
    </div>
</div>

<!-- ══ PRINT STYLES ══ -->
<style>
    @@media print {
        body * { visibility: hidden !important; }
        #printArea, #printArea * { visibility: visible !important; }
        #printArea {
            position: fixed !important;
            top: 0; left: 0;
            width: 100%;
            padding: 0;
            background: #fff;

        }

        .no-print {
        display: none !important;
    }

        /* Header */
        .ph-header {
            display: flex !important;
            align-items: center;
            justify-content: space-between;
            border-bottom: 3px solid #1E66D0;
            padding: 18px 28px 14px;
            margin-bottom: 0;
        }
        .ph-logo {
            width: 80px;
            height: 80px;
            object-fit: contain;
        }
        .ph-center { text-align: center; flex: 1; padding: 0 16px; }
        .ph-center h2 {
            font-size: 17px;
            font-weight: 700;
            color: #1a2742;
            margin: 0 0 3px;
        }
        .ph-center h3 {
            font-size: 13px;
            color: #1E66D0;
            font-weight: 600;
            margin: 0 0 2px;
        }
        .ph-center p {
            font-size: 11px;
            color: #555;
            margin: 0;
        }
        .ph-right { text-align: right; font-size: 11px; color: #555; min-width: 120px; }
        .ph-right strong { display: block; font-size: 13px; color: #1a2742; }

        /* Meta bar */
        .ph-meta {
            background: #f0f5ff;
            padding: 7px 28px;
            font-size: 11px;
            color: #444;
            display: flex !important;
            gap: 24px;
            border-bottom: 1px solid #dde6f5;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }
        .ph-meta span strong { color: #1E66D0; }

        /* Table */
        .ph-table-wrap { padding: 12px 28px; }
        #printArea table {
            width: 100%;
            border-collapse: collapse;
            font-size: 11.5px;
        }
        #printArea th,
        #printArea td {
            border: 1px solid #ccc;
            padding: 6px 9px;
            text-align: left;
        }
        #printArea th {
            background: #1E66D0 !important;
            color: #fff !important;
            font-weight: 600;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }
        #printArea tr:nth-child(even) td {
            background: #f7f9ff !important;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }

        /* Footer */
        .ph-footer {
            border-top: 2px solid #1E66D0;
            padding: 10px 28px;
            display: flex !important;
            justify-content: space-between;
            font-size: 10px;
            color: #888;
            margin-top: 8px;
        }

        @@page { margin: 0; }
    }

    .ph-center { 
            text-align: center; 
            width: 100% ;
            display: block ;
        }
        .ph-center-logo-wrap img {
            display: block;
            margin: 0 auto;
        }
</style>

<!-- ══ HIDDEN PRINT AREA ══ -->
<div id="printArea" style="display:none;">

    <!-- HEADER -->
    <div class="ph-header">
        
        <div class="ph-center">
            <h2>Degmada Yaaqoshiid — Yaqoshiid District</h2>
            <h3>Online Marriage Certificate System</h3>
            <p>Official Applications Report</p>
            
            <div class="ph-center-logo-wrap" style="margin-top: 10px;">
                <img class="ph-logo" src="~/images/logo.jpg" alt="Logo" style="width: 55px; height: 55px; object-fit: contain;" />
            </div>
        </div>
        <div class="ph-right">
            <strong id="printDate"></strong>
            <span>Yaaqoshiid, Somalia</span>
        </div>
    </div>

    <!-- META BAR -->
    <div class="ph-meta no-print d-print-none" style="display: none !important;">
        <span>Status: <strong id="printStatus">All</strong></span>
        <span>Search: <strong id="printSearch">—</strong></span>
        <span>Total Records: <strong id="printTotal">0</strong></span>
        <span>Generated by: <strong>Admin Portal</strong></span>
    </div>

    <!-- TABLE -->
    <div class="ph-table-wrap">
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Ref No</th>
                    <th>Husband</th>
                    <th>Wife</th>
                    <th>Amount</th>
                    <th>Payment</th>
                    <th>Status</th>
                    <th>Date</th>
                </tr>
            </thead>
            <tbody id="printBody"></tbody>
        </table>
    </div>

    <!-- FOOTER -->
    <div class="ph-footer">
        <span>Degmada Yaaqoshiid — Online Marriage Certificate Information Management System</span>
        <span id="printFooterDate"></span>
    </div>
</div>

<script>
const RAW = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Rows.Select(r => new {
    i    = r.Id,
    ref_ = r.RefNo,
    hus  = r.Husband,
    wife = r.Wife,
    amt  = r.Amount,
    pay  = r.Payment,
    sta  = r.Status,
    dat  = r.Date.ToString("yyyy-MM-dd")
})));

let filtered = [...RAW];
let page     = 1;
let sortKey  = '';
let sortAsc  = true;

function statusBadge(s) {
    if (s === 'Approved') return '<span class="badge badge-success">Approved</span>';
    if (s === 'Rejected') return '<span class="badge badge-danger">Rejected</span>';
    if (s === 'Pending')  return '<span class="badge badge-warning">Pending</span>';
    return '<span class="badge badge-secondary">' + s + '</span>';
}

function payBadge(p) {
    if (p === 'Approved') return '<span class="badge badge-primary">Paid</span>';
    return '<span class="badge badge-secondary">Unpaid</span>';
}

function renderTable() {
    const q  = document.getElementById('searchBox').value.toLowerCase();
    const st = document.getElementById('statusFilter').value.toLowerCase();
    const pp = parseInt(document.getElementById('perPage').value);

    filtered = RAW.filter(r => {
        const matchQ  = !q  || r.ref_.toLowerCase().includes(q) ||
                               r.hus.toLowerCase().includes(q)  ||
                               r.wife.toLowerCase().includes(q) ||
                               r.sta.toLowerCase().includes(q)  ||
                               r.pay.toLowerCase().includes(q);
        const matchSt = !st || r.sta.toLowerCase() === st;
        return matchQ && matchSt;
    });

    if (sortKey) {
        filtered.sort((a, b) => {
            let av = a[sortKey], bv = b[sortKey];
            if (typeof av === 'number' && typeof bv === 'number')
                return sortAsc ? av - bv : bv - av;
            av = String(av).toLowerCase();
            bv = String(bv).toLowerCase();
            return sortAsc ? (av > bv ? 1 : -1) : (av < bv ? 1 : -1);
        });
    }

    const total = filtered.length;
    document.getElementById('totalCount').textContent = total;

    const pages = Math.max(1, Math.ceil(total / pp));
    if (page > pages) page = 1;

    const start = (page - 1) * pp;
    const slice = filtered.slice(start, start + pp);

    document.getElementById('tBody').innerHTML = slice.length === 0
        ? '<tr><td colspan="8" class="text-center text-muted py-4">No entries found</td></tr>'
        : slice.map((r, idx) => '<tr>' +
            '<td>' + (start + idx + 1) + '</td>' +
            '<td><code>' + r.ref_ + '</code></td>' +
            '<td>' + r.hus + '</td>' +
            '<td>' + r.wife + '</td>' +
            '<td>$' + parseFloat(r.amt).toFixed(2) + '</td>' +
            '<td>' + payBadge(r.pay) + '</td>' +
            '<td>' + statusBadge(r.sta) + '</td>' +
            '<td>' + r.dat + '</td>' +
          '</tr>').join('');

    const end = Math.min(start + pp, total);
    document.getElementById('infoText').textContent = total === 0
        ? 'No entries found'
        : 'Showing ' + (start + 1) + ' to ' + end + ' of ' + total + ' entries';

    let nums = '<li class="page-item' + (page===1?' disabled':'') + '">' +
               '<a class="page-link" href="#" onclick="prevPage();return false;">\u00ab</a></li>';
    for (let p = 1; p <= pages; p++) {
        nums += '<li class="page-item' + (p===page?' active':'') + '">' +
                '<a class="page-link" href="#" onclick="goPage(' + p + ');return false;">' + p + '</a></li>';
    }
    nums += '<li class="page-item' + (page===pages?' disabled':'') + '">' +
            '<a class="page-link" href="#" onclick="nextPage();return false;">\u00bb</a></li>';
    document.getElementById('pageNums').innerHTML = nums;
}

function printReport() {
    const statusVal = document.getElementById('statusFilter').value || 'All';
    const searchVal = document.getElementById('searchBox').value   || '—';
    const now       = new Date().toLocaleString('en-GB', {
        day:'2-digit', month:'short', year:'numeric',
        hour:'2-digit', minute:'2-digit'
    });

    document.getElementById('printDate').textContent      = now;
    document.getElementById('printFooterDate').textContent = 'Printed: ' + now;
    document.getElementById('printStatus').textContent    = statusVal;
    document.getElementById('printSearch').textContent    = searchVal;
    document.getElementById('printTotal').textContent     = filtered.length;

    document.getElementById('printBody').innerHTML = filtered.length === 0
        ? '<tr><td colspan="8" class="text-center">No entries found</td></tr>'
        : filtered.map((r, idx) => '<tr>' +
            '<td>' + (idx + 1) + '</td>' +
            '<td>' + r.ref_ + '</td>' +
            '<td>' + r.hus + '</td>' +
            '<td>' + r.wife + '</td>' +
            '<td>$' + parseFloat(r.amt).toFixed(2) + '</td>' +
            '<td>' + (r.pay === 'Approved' ? 'Paid' : 'Unpaid') + '</td>' +
            '<td>' + r.sta + '</td>' +
            '<td>' + r.dat + '</td>' +
          '</tr>').join('');

    document.getElementById('printArea').style.display = 'block';
    window.print();
    document.getElementById('printArea').style.display = 'none';
}

function prevPage() { if (page > 1) { page--; renderTable(); } }
function nextPage()  { page++; renderTable(); }
function goPage(p)   { page = p; renderTable(); }

document.getElementById('searchBox').addEventListener('input',    () => { page=1; renderTable(); });
document.getElementById('statusFilter').addEventListener('change', () => { page=1; renderTable(); });
document.getElementById('perPage').addEventListener('change',     () => { page=1; renderTable(); });

renderTable();
</script>
