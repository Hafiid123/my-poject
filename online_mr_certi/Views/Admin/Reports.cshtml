@model ReportsViewModel
@{
    ViewData["Title"] = "Reports";
}

    
        <div class="card">
            <div class="card-header"><h3 class="card-title">Submissions by month (last 12)</h3></div>
            <div class="card-body table-responsive p-0">
                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th>Period</th>
                            <th>Total</th>
                            <th>Pending</th>
                            <th>Approved</th>
                            <th>Rejected</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.ByMonth)
                        {
                            <tr>
                                <td>@row.Period</td>
                                <td>@row.Total</td>
                                <td>@row.Pending</td>
                                <td>@row.Approved</td>
                                <td>@row.Rejected</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    
