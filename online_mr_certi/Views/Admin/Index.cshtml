@using System.Text.Json
@using online_mr_certi.Models
@model online_mr_certi.Models.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";

    static string TimeAgo(DateTime utc)
    {
        var span = DateTime.UtcNow - utc;
        if (span.TotalMinutes < 1) return "just now";
        if (span.TotalHours < 1) return $"{(int)span.TotalMinutes} minute(s) ago";
        if (span.TotalDays < 1) return $"{(int)span.TotalHours} hour(s) ago";
        return $"{(int)span.TotalDays} day(s) ago";
    }
}

<div class="row">
    <div class="col-lg col-md-6 col-6">
        <div class="small-box bg-info">
            <div class="inner">
                <h3>@Model.TotalApplications</h3>
                <p>Applications</p>
            </div>
            <div class="icon"><i class="fas fa-file-alt"></i></div>
            <a asp-action="Applications" class="small-box-footer">View <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>
    <div class="col-lg col-md-6 col-6">
        <div class="small-box bg-secondary">
            <div class="inner">
                <h3>@Model.PendingPayment</h3>
                <p>Awaiting payment</p>
            </div>
            <div class="icon"><i class="fas fa-mobile-alt"></i></div>
            <a asp-action="Applications" asp-route-status="@ApplicationStatus.PendingPayment" class="small-box-footer">List <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>
    <div class="col-lg col-md-6 col-6">
        <div class="small-box bg-warning">
            <div class="inner">
                <h3>@Model.Pending</h3>
                <p>Pending review</p>
            </div>
            <div class="icon"><i class="fas fa-hourglass-half"></i></div>
            <a asp-action="Applications" asp-route-status="@ApplicationStatus.Pending" class="small-box-footer">Review <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>
    <div class="col-lg col-md-6 col-6">
        <div class="small-box bg-success">
            <div class="inner">
                <h3>@Model.Approved</h3>
                <p>Approved</p>
            </div>
            <div class="icon"><i class="fas fa-check"></i></div>
            <a asp-action="Applications" asp-route-status="@ApplicationStatus.Approved" class="small-box-footer">List <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>
    <div class="col-lg col-md-6 col-6">
        <div class="small-box bg-danger">
            <div class="inner">
                <h3>@Model.Rejected</h3>
                <p>Rejected</p>
            </div>
            <div class="icon"><i class="fas fa-times"></i></div>
            <a asp-action="Applications" asp-route-status="@ApplicationStatus.Rejected" class="small-box-footer">List <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>
</div>

@* --- ROW 1: 3 Charts oo isku xarig ah --- *@
<div class="row items-stretch">
    @* Chart 1: Application Trends *@
    <div class="col-lg-4 mb-4">
        <div class="card h-100 shadow-sm border-0" style="border-radius: 12px;">
            <div class="card-header bg-white border-0 pt-3">
                <h3 class="card-title text-bold" style="font-size: 1.1rem;">
                    <i class="fas fa-chart-line text-primary mr-2"></i>Application Trends
                </h3>
            </div>
            <div class="card-body">
                <div style="height: 250px; width: 100%;">
                    <canvas id="trendChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    @* Chart 2: Payment Trends *@
    <div class="col-lg-4 mb-4">
        <div class="card h-100 shadow-sm border-0" style="border-radius: 12px;">
            <div class="card-header bg-white border-0 pt-3 d-flex justify-content-between align-items-center">
                <h3 class="card-title text-bold mb-0" style="font-size: 1.1rem;">
                    <i class="fas fa-credit-card text-success mr-2"></i>Payment Trends
                </h3>
                <span class="badge badge-success px-2 py-1" style="font-size: 0.75rem; border-radius: 6px;">
                    $@Model.TotalRevenue.ToString("N2")
                </span>
            </div>
            <div class="card-body">
                <div style="height: 250px; width: 100%;">
                    <canvas id="paymentTrendChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    @* Chart 3: Status Breakdown *@
    <div class="col-lg-4 mb-4">
        <div class="card h-100 shadow-sm border-0" style="border-radius: 12px;">
            <div class="card-header bg-white border-0 pt-3">
                <h3 class="card-title text-bold" style="font-size: 1.1rem;">
                    <i class="fas fa-chart-pie text-info mr-2"></i>Status Breakdown
                </h3>
            </div>
            <div class="card-body d-flex align-items-center justify-content-center">
                <div style="height: 220px; width: 100%;">
                    <canvas id="statusChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@* --- ROW 2: 3 Cards oo isku xarig ah --- *@
<div class="row items-stretch">
    @* Card 1: Payment Summary *@
    <div class="col-lg-4 mb-4">
        <div class="card h-100 shadow-sm">
            <div class="card-header border-0">
                <h3 class="card-title text-bold">Payment Summary</h3>
            </div>
            <div class="card-body d-flex flex-column justify-content-center">
                <div class="info-box mb-3 shadow-none border" style="border-radius: 10px;">
                    <span class="info-box-icon bg-success" style="border-radius: 10px 0 0 10px;">
                        <i class="fas fa-check-circle"></i>
                    </span>
                    <div class="info-box-content">
                        <span class="info-box-text">Approved Payments</span>
                        <span class="info-box-number">@Model.TotalPaidPayments</span>
                    </div>
                </div>
                <div class="info-box mb-3 shadow-none border" style="border-radius: 10px;">
                    <span class="info-box-icon bg-warning" style="border-radius: 10px 0 0 10px;">
                        <i class="fas fa-hourglass-half"></i>
                    </span>
                    <div class="info-box-content">
                        <span class="info-box-text">Pending Payments</span>
                        <span class="info-box-number">@Model.TotalPendingPayments</span>
                    </div>
                </div>
                <div class="info-box shadow-none border" style="border-radius: 10px;">
                    <span class="info-box-icon bg-primary" style="border-radius: 10px 0 0 10px;">
                        <i class="fas fa-dollar-sign"></i>
                    </span>
                    <div class="info-box-content">
                        <span class="info-box-text">Total Revenue</span>
                        <span class="info-box-number">$@Model.TotalRevenue.ToString("N2")</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Card 2: Recent Activity *@
    <div class="col-lg-4 mb-4">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-header bg-white border-0 pt-3">
                <h3 class="card-title text-bold">
                    <i class="fas fa-history text-muted mr-2"></i>Recent Activity
                </h3>
            </div>
            <div class="card-body p-0" style="max-height: 350px; overflow-y: auto;">
                <div class="timeline-v2 p-3">
                    @foreach (var activity in Model.RecentActivities)
                    {
                        <div class="timeline-item-v2">
                            @{
                                var iconClass = "bg-primary";
                                var icon = "fa-info";

                                if (activity.Message.Contains("Approved", StringComparison.OrdinalIgnoreCase)) { iconClass = "bg-success"; icon = "fa-check"; }
                                else if (activity.Message.Contains("Rejected", StringComparison.OrdinalIgnoreCase)) { iconClass = "bg-danger"; icon = "fa-times"; }
                                else if (activity.Message.Contains("Payment", StringComparison.OrdinalIgnoreCase)) { iconClass = "bg-info"; icon = "fa-credit-card"; }
                            }

                            <div class="timeline-badge @iconClass shadow-sm">
                                <i class="fas @icon"></i>
                            </div>
                            <div class="timeline-content">
                                <div class="d-flex justify-content-between">
                                    <p class="mb-0 text-sm font-weight-600">@activity.Message</p>
                                </div>
                                <small class="text-muted"><i class="far fa-clock mr-1"></i>@TimeAgo(activity.CreatedAt)</small>
                            </div>
                        </div>
                    }

                    @if (Model.RecentActivities.Count == 0)
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-stream fa-2x text-light mb-2"></i>
                            <p class="text-muted small">No recent logs found</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    @* --- Card 3: PREMIUM MODERN - Pending Reviews --- *@
    <div class="col-lg-4 mb-4">
        <div class="card h-100 border-0" style="border-radius: 16px; background: #ffffff; box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);">
            <div class="card-header bg-white border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                <div>
                    <h3 class="card-title text-bold mb-1" style="font-size: 1.15rem; color: #1e293b; letter-spacing: -0.3px;">
                        <i class="fas fa-gavel text-warning mr-2" style="font-size: 1.05rem;"></i>Pending Reviews
                    </h3>
                    <p class="text-muted mb-0" style="font-size: 0.78rem;">Applications requiring court verification</p>
                </div>
                <span class="badge px-3 py-2 font-weight-bold" style="font-size: 0.75rem; border-radius: 20px; background-color: #fffbeb; color: #b45309; border: 1px solid #fde68a;">
                    @Model.FilteredApplications.Count(a => a.Status == ApplicationStatus.Pending) Active
                </span>
            </div>
            <div class="card-body px-4 pt-3 pb-4" style="max-height: 380px; overflow-y: auto;">
                <div class="d-flex flex-column" style="gap: 12px;">
                    @foreach (var row in Model.FilteredApplications.Where(a => a.Status == ApplicationStatus.Pending))
                    {
                        <div class="p-3 border" style="border-radius: 12px; background: #ffffff; border-color: #e2e8f0 !important; transition: all 0.25s ease; cursor: pointer;"
                             onmouseover="this.style.borderColor='#cbd5e1'; this.style.transform='translateY(-2px)'; this.style.boxShadow='0 4px 12px rgba(0,0,0,0.03)';"
                             onmouseout="this.style.borderColor='#e2e8f0'; this.style.transform='translateY(0)'; this.style.boxShadow='none';">

                            @* Top Meta Meta *@
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="font-weight-bold text-primary" style="font-size: 0.8rem; background: #eff6ff; padding: 4px 10px; border-radius: 8px;">
                                    #@row.Id
                                </span>
                                <span class="text-muted" style="font-size: 0.75rem; font-weight: 500;">
                                    <i class="far fa-clock mr-1" style="color: #94a3b8;"></i>@row.SubmissionDate.ToString("MMM dd, HH:mm")
                                </span>
                            </div>

                            @* Main Details *@
                            <div class="d-flex align-items-start mb-3">
                                <div class="rounded-circle d-flex align-items-center justify-content-center mr-3 shadow-sm"
                                     style="width: 38px; height: 38px; background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%); border: 1px solid #e2e8f0;">
                                    <i class="fas fa-heart text-danger" style="font-size: 0.9rem;"></i>
                                </div>
                                <div style="flex: 1; min-width: 0;">
                                    <h6 class="mb-1 font-weight-bold text-dark text-truncate" style="font-size: 0.92rem; color: #0f172a !important;">
                                        @row.ApplicantName
                                    </h6>
                                    <div class="d-flex align-items-center text-muted" style="font-size: 0.75rem; gap: 4px;">
                                        <i class="fas fa-map-marker-alt" style="color: #64748b;"></i>
                                        <span>Yaqshiid District Court</span>
                                    </div>
                                </div>
                            </div>

                            @* Bottom Pro Button Container *@
                            <div class="pt-2 border-top d-flex justify-content-between align-items-center" style="border-color: #f1f5f9 !important;">
                                <span class="text-muted" style="font-size: 0.72rem; font-weight: 500;">Status: <span class="text-warning font-weight-bold">Awaiting Review</span></span>
                                <a asp-action="ApplicationDetails" asp-route-id="@row.Id" class="btn btn-sm px-3 font-weight-bold text-white shadow-sm"
                                   style="font-size: 0.78rem; border-radius: 8px; background: #0f172a; border: none; transition: background 0.2s;"
                                   onmouseover="this.style.background='#1e293b';" onmouseout="this.style.background='#0f172a';">
                                    <i class="fas fa-search mr-1" style="font-size: 0.7rem;"></i> Process Case
                                </a>
                            </div>
                        </div>
                    }

                    @if (!Model.FilteredApplications.Any(a => a.Status == ApplicationStatus.Pending))
                    {
                        <div class="text-center py-5">
                            <div class="mb-3 d-inline-flex align-items-center justify-content-center rounded-circle"
                                 style="width: 56px; height: 56px; background-color: #f0fdf4; color: #16a34a;">
                                <i class="fas fa-check-circle fa-2x"></i>
                            </div>
                            <h6 class="font-weight-bold mb-1" style="color: #1e293b; font-size: 0.95rem;">All Caught Up!</h6>
                            <p class="text-muted mb-0" style="font-size: 0.8rem;">There are no marriage certificates waiting.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        let trendChart, statusChart;

        function initCharts() {
            const trendLabels  = @Html.Raw(JsonSerializer.Serialize(Model.TrendLabels));
            const trendValues  = @Html.Raw(JsonSerializer.Serialize(Model.TrendValues));
            const statusValues = @Html.Raw(JsonSerializer.Serialize(new[] { Model.StatusApproved, Model.StatusRejected, Model.StatusPending }));

            // Application Trend Line Chart
            const ctxTrend = document.getElementById('trendChart').getContext('2d');
            trendChart = new Chart(ctxTrend, {
                type: 'line',
                data: {
                    labels: trendLabels,
                    datasets: [{
                        label: 'Applications',
                        data: trendValues,
                        borderColor: '#2F80ED',
                        backgroundColor: 'rgba(47, 128, 237, 0.15)',
                        tension: 0.4,
                        fill: true,
                        pointRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
                }
            });

            // Status Pie Chart
            const ctxStatus = document.getElementById('statusChart').getContext('2d');
            statusChart = new Chart(ctxStatus, {
                type: 'pie',
                data: {
                    labels: ['Approved', 'Rejected', 'Pending'],
                    datasets: [{
                        data: statusValues,
                        backgroundColor: ['#28a745', '#dc3545', '#ffc107'],
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { position: 'top' } }
                }
            });

            // Payment Trend Bar Chart (CUSUB)
            const paymentLabels = @Html.Raw(JsonSerializer.Serialize(Model.PaymentTrendLabels));
            const paymentValues = @Html.Raw(JsonSerializer.Serialize(Model.PaymentTrendValues));

            const ctxPayment = document.getElementById('paymentTrendChart').getContext('2d');
            new Chart(ctxPayment, {
                type: 'bar',
                data: {
                    labels: paymentLabels,
                    datasets: [{
                        label: 'Approved Payments',
                        data: paymentValues,
                        backgroundColor: 'rgba(40, 167, 69, 0.75)',
                        borderColor: '#28a745',
                        borderWidth: 2,
                        borderRadius: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
                }
            });
        }

        // AJAX Search Logic
        const searchInput = document.querySelector('#dashboardSearchForm input[name="q"]');
        const searchForm  = document.getElementById('dashboardSearchForm');
        let timer;

        searchInput?.addEventListener('input', function () {
            clearTimeout(timer);
            timer = setTimeout(() => {
                const query  = searchInput.value;
                const status = document.querySelector('input[name="status"]').value;
                const url    = `@Url.Action("Index", "Admin")?q=${encodeURIComponent(query)}&status=${status}`;

                fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                    .then(response => response.text())
                    .then(html => {
                        const parser   = new DOMParser();
                        const doc      = parser.parseFromString(html, 'text/html');
                        const newTable = doc.querySelector('#table-results');
                        if (newTable) {
                            document.getElementById('table-results').innerHTML = newTable.innerHTML;
                        }
                    })
                    .catch(err => console.warn("Search error:", err));
            }, 450);
        });

        searchForm?.addEventListener('submit', (e) => e.preventDefault());

        document.addEventListener('DOMContentLoaded', initCharts);
    </script>



    <style>
        .timeline-v2 {
            position: relative;
        }

            .timeline-v2::before {
                content: '';
                position: absolute;
                top: 0;
                bottom: 0;
                left: 27px;
                width: 2px;
                background: #f1f3f5;
            }

        .timeline-item-v2 {
            position: relative;
            padding-left: 55px;
            margin-bottom: 25px;
        }

        .timeline-badge {
            position: absolute;
            left: 15px;
            width: 26px;
            height: 26px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 11px;
            z-index: 2;
        }

        .timeline-content {
            background: transparent;
        }

        .font-weight-600 {
            font-weight: 600;
        }

        .card-body::-webkit-scrollbar {
            width: 4px;
        }

        .card-body::-webkit-scrollbar-thumb {
            background: #e9ecef;
            border-radius: 10px;
        }
    </style>
}
