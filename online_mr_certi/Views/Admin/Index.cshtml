@using System.Text.Json
@using online_mr_certi.Models
@model online_mr_certi.Models.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";

    static string TimeAgo(DateTime utc)
    {
        var span = DateTime.UtcNow - utc;
        if (span.TotalMinutes < 1) return "just now";
        if (span.TotalHours < 1) return $"{(int)span.TotalMinutes} minute(s) ago";
        if (span.TotalDays < 1) return $"{(int)span.TotalHours} hour(s) ago";
        return $"{(int)span.TotalDays} day(s) ago";
    }
}

<div class="row">
    <div class="col-lg col-md-6 col-6">
        <div class="small-box bg-info">
            <div class="inner">
                <h3>@Model.TotalApplications</h3>
                <p>Applications</p>
            </div>
            <div class="icon"><i class="fas fa-file-alt"></i></div>
            <a asp-action="Applications" class="small-box-footer">View <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>
    <div class="col-lg col-md-6 col-6">
        <div class="small-box bg-secondary">
            <div class="inner">
                <h3>@Model.PendingPayment</h3>
                <p>Awaiting payment</p>
            </div>
            <div class="icon"><i class="fas fa-mobile-alt"></i></div>
            <a asp-action="Applications" asp-route-status="@ApplicationStatus.PendingPayment" class="small-box-footer">List <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>
    <div class="col-lg col-md-6 col-6">
        <div class="small-box bg-warning">
            <div class="inner">
                <h3>@Model.Pending</h3>
                <p>Pending review</p>
            </div>
            <div class="icon"><i class="fas fa-hourglass-half"></i></div>
            <a asp-action="Applications" asp-route-status="@ApplicationStatus.Pending" class="small-box-footer">Review <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>
    <div class="col-lg col-md-6 col-6">
        <div class="small-box bg-success">
            <div class="inner">
                <h3>@Model.Approved</h3>
                <p>Approved</p>
            </div>
            <div class="icon"><i class="fas fa-check"></i></div>
            <a asp-action="Applications" asp-route-status="@ApplicationStatus.Approved" class="small-box-footer">List <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>
    <div class="col-lg col-md-6 col-6">
        <div class="small-box bg-danger">
            <div class="inner">
                <h3>@Model.Rejected</h3>
                <p>Rejected</p>
            </div>
            <div class="icon"><i class="fas fa-times"></i></div>
            <a asp-action="Applications" asp-route-status="@ApplicationStatus.Rejected" class="small-box-footer">List <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>
</div>

@* --- Qaybta Chart-yada (Halkan ayaa la beddelay) --- *@
<div class="row items-stretch">
    <div class="col-lg-8 mb-4">
        <div class="card h-100 shadow-sm">
            <div class="card-header border-0">
                <h3 class="card-title text-bold">Application Trends (Last 7 Days)</h3>
            </div>
            <div class="card-body">
                <div style="height: 300px;">
                    <canvas id="trendChart"></canvas>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4 mb-4">
        <div class="card h-100 shadow-sm">
            <div class="card-header border-0">
                <h3 class="card-title text-bold">Status Breakdown</h3>
            </div>
            @* d-flex iyo align-items-center waxay dhexda keenayaan Pie-ka *@
            <div class="card-body d-flex align-items-center justify-content-center">
                <div style="height: 250px; width: 100%;">
                    <canvas id="statusChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@* --- Search iyo Recent Activity --- *@
<div class="row">
    <div class="col-lg-5">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-header bg-white border-0 pt-3">
                <h3 class="card-title text-bold">
                    <i class="fas fa-history text-muted mr-2"></i>Recent Activity
                </h3>
            </div>
            <div class="card-body p-0" style="max-height: 450px; overflow-y: auto;">
                <div class="timeline-v2 p-3">
                    @foreach (var activity in Model.RecentActivities)
                    {
                        <div class="timeline-item-v2">
                            @* Icon-ka midabkiisa wuxuu isku beddelayaa hadba waxa dhacay *@
                            @{
                                var iconClass = "bg-primary";
                                var icon = "fa-info";

                                if (activity.Message.Contains("Approved", StringComparison.OrdinalIgnoreCase)) { iconClass = "bg-success"; icon = "fa-check"; }
                                else if (activity.Message.Contains("Rejected", StringComparison.OrdinalIgnoreCase)) { iconClass = "bg-danger"; icon = "fa-times"; }
                                else if (activity.Message.Contains("Payment", StringComparison.OrdinalIgnoreCase)) { iconClass = "bg-info"; icon = "fa-credit-card"; }
                            }

                            <div class="timeline-badge @iconClass shadow-sm">
                                <i class="fas @icon"></i>
                            </div>
                            <div class="timeline-content">
                                <div class="d-flex justify-content-between">
                                    <p class="mb-0 text-sm font-weight-600">@activity.Message</p>
                                </div>
                                <small class="text-muted"><i class="far fa-clock mr-1"></i>@TimeAgo(activity.CreatedAt)</small>
                            </div>
                        </div>
                    }

                    @if (Model.RecentActivities.Count == 0)
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-stream fa-2x text-light mb-2"></i>
                            <p class="text-muted small">No recent logs found</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-7">
        <div class="card shadow-sm h-100 border-0">
            <div class="card-header bg-white border-0 pt-3">
                <h3 class="card-title text-bold"><i class="fas fa-filter text-muted mr-2"></i>Search & Quick Filters</h3>
            </div>
            <div class="card-body">
                <form method="get" asp-action="Index" class="mb-4" id="dashboardSearchForm">
                    <div class="input-group input-group-lg shadow-sm">
                        <div class="input-group-prepend">
                            <span class="input-group-text bg-white border-right-0 text-muted">
                                <i class="fas fa-search"></i>
                            </span>
                        </div>
                        <input type="text" class="form-control border-left-0 pl-0" name="q" value="@Model.SearchQuery"
                               placeholder="Search Application ID or Name..." style="font-size: 1rem;" />
                        <input type="hidden" name="status" value="@Model.StatusFilter" />
                    </div>
                </form>

                <div class="d-flex flex-wrap gap-2 mb-4" style="gap: 8px;">
                    <a asp-action="Index" asp-route-q="@Model.SearchQuery"
                       class="btn btn-sm px-3 rounded-pill @(string.IsNullOrWhiteSpace(Model.StatusFilter) ? "btn-dark shadow" : "btn-outline-dark")">
                        All
                    </a>

                    <a asp-action="Index" asp-route-q="@Model.SearchQuery" asp-route-status="@ApplicationStatus.PendingPayment"
                       class="btn btn-sm px-3 rounded-pill @(Model.StatusFilter == ApplicationStatus.PendingPayment ? "btn-secondary shadow" : "btn-outline-secondary")">
                        <i class="fas fa-credit-card mr-1"></i> Pending Payment
                    </a>

                    <a asp-action="Index" asp-route-q="@Model.SearchQuery" asp-route-status="@ApplicationStatus.Pending"
                       class="btn btn-sm px-3 rounded-pill @(Model.StatusFilter == ApplicationStatus.Pending ? "btn-warning shadow" : "btn-outline-warning")">
                        <i class="fas fa-hourglass-half mr-1"></i> Pending Review
                    </a>

                    <a asp-action="Index" asp-route-q="@Model.SearchQuery" asp-route-status="@ApplicationStatus.Approved"
                       class="btn btn-sm px-3 rounded-pill @(Model.StatusFilter == ApplicationStatus.Approved ? "btn-success shadow" : "btn-outline-success")">
                        <i class="fas fa-check-circle mr-1"></i> Approved
                    </a>

                    <a asp-action="Index" asp-route-q="@Model.SearchQuery" asp-route-status="@ApplicationStatus.Rejected"
                       class="btn btn-sm px-3 rounded-pill @(Model.StatusFilter == ApplicationStatus.Rejected ? "btn-danger shadow" : "btn-outline-danger")">
                        <i class="fas fa-times-circle mr-1"></i> Rejected
                    </a>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="text-muted" style="background-color: #f8f9fa; font-size: 0.85rem; text-transform: uppercase;">
                            <tr>
                                <th class="border-0 pl-3">ID</th>
                                <th class="border-0">Applicant Details</th>
                                <th class="border-0 text-center">Status</th>
                                <th class="border-0 text-right pr-3">Submitted</th>
                            </tr>
                        </thead>
                        <tbody id="table-results">
                            @foreach (var row in Model.FilteredApplications)
                            {
                                <tr>
                                    <td class="pl-3 align-middle">
                                        <a asp-action="ApplicationDetails" asp-route-id="@row.Id" class="text-primary font-weight-bold">#@row.Id</a>
                                    </td>
                                    <td class="align-middle">
                                        <div class="font-weight-bold text-dark">@row.ApplicantName</div>
                                        @* <div class="small text-muted">@row.ApplicantEmail</div> *@
                                    </td>
                                    <td class="text-center align-middle">
                                        @if (row.Status == ApplicationStatus.Approved)
                                        {
                                            <span class="badge badge-pill badge-success px-3">Approved</span>
                                        }
                                        else if (row.Status == ApplicationStatus.Rejected)
                                        {

                                            <span class="badge badge-pill badge-danger px-3">Rejected</span>
                                        }
                                        else if (row.Status == ApplicationStatus.PendingPayment)
                                        {

                                            <span class="badge badge-pill badge-secondary px-3">Awaiting Payment</span>
                                        }
                                        else
                                        {

                                            <span class="badge badge-pill badge-warning px-3">@row.Status</span>
                                        }
                                    </td>
                                    <td class="text-right pr-3 align-middle">
                                        <span class="text-dark small">@row.SubmissionDate.ToString("MMM dd, yyyy")</span><br />
                                        <small class="text-muted">@row.SubmissionDate.ToString("HH:mm")</small>
                                    </td>
                                </tr>
                            }
                            @if (Model.FilteredApplications.Count == 0)
                            {
                                <tr><td colspan="4" class="text-muted text-center py-5">No matching applications found.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // 1. Qeex variables-ka Charts-ka si caalami ah
        let trendChart, statusChart;

        function initCharts() {
            const trendLabels = @Html.Raw(JsonSerializer.Serialize(Model.TrendLabels));
            const trendValues = @Html.Raw(JsonSerializer.Serialize(Model.TrendValues));
            const statusValues = @Html.Raw(JsonSerializer.Serialize(new[] { Model.StatusApproved, Model.StatusRejected, Model.StatusPending }));

            // Trend Line Chart
            const ctxTrend = document.getElementById('trendChart').getContext('2d');
            trendChart = new Chart(ctxTrend, {
                type: 'line',
                data: {
                    labels: trendLabels,
                    datasets: [{
                        label: 'Applications',
                        data: trendValues,
                        borderColor: '#2F80ED',
                        backgroundColor: 'rgba(47, 128, 237, 0.15)',
                        tension: 0.4,
                        fill: true,
                        pointRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
                }
            });

            // Status Pie Chart
            const ctxStatus = document.getElementById('statusChart').getContext('2d');
            statusChart = new Chart(ctxStatus, {
                type: 'pie',
                data: {
                    labels: ['Approved', 'Rejected', 'Pending'],
                    datasets: [{
                        data: statusValues,
                        backgroundColor: ['#28a745', '#dc3545', '#ffc107'],
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { position: 'top' } }
                }
            });
        }

        // 2. AJAX Search Logic
        const searchInput = document.querySelector('#dashboardSearchForm input[name="q"]');
        const searchForm = document.getElementById('dashboardSearchForm');
        let timer;

        searchInput?.addEventListener('input', function () {
            clearTimeout(timer);
            timer = setTimeout(() => {
                const query = searchInput.value;
                const status = document.querySelector('input[name="status"]').value;
                const url = `@Url.Action("Index", "Admin")?q=${encodeURIComponent(query)}&status=${status}`;

                fetch(url, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(response => response.text())
                .then(html => {
                    const parser = new DOMParser();
                    const doc = parser.parseFromString(html, 'text/html');
                    const newTable = doc.querySelector('#table-results');

                    if (newTable) {
                        document.getElementById('table-results').innerHTML = newTable.innerHTML;
                    }
                })
                .catch(err => console.warn("Search error:", err));
            }, 450);
        });

        // Jooji inuu bogga Refresh gareeyo markii Enter la riixo
        searchForm?.addEventListener('submit', (e) => e.preventDefault());

        // Daaran Charts-ka marka bogga la raryo
        document.addEventListener('DOMContentLoaded', initCharts);
    </script>

